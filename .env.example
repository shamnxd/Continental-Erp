# =========================================================================
# GLOBAL DOCKER-COMPOSE CONFIGURATION ENV TEMPLATE (DO NOT ADD SECRETS HERE)
# =========================================================================

# MongoDB URI (Set host.docker.internal to target the host VPS database)
MONGO_URI=mongodb://host.docker.internal:27017/continental_service

# Secrets (Change these in production to long secure strings)
JWT_ACCESS_SECRET=your_super_secure_production_access_key
JWT_REFRESH_SECRET=your_super_secure_production_refresh_key

# JWT Expiration Details
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_NAME_REFRESH=refreshToken
LOG_RETENTION_DAYS=7

# Allowed Frontend Origins (Comma separated)
FRONTEND_URL=https://client.contproj.com,https://staff.contproj.com,https://admin.contproj.com

# Frontend API Target (Build argument for Vite compilation inside container)
VITE_API_URL=https://api.contproj.com/api/v1
