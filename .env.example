# =========================================================================
# GLOBAL DOCKER-COMPOSE CONFIGURATION ENV TEMPLATE (DO NOT ADD SECRETS HERE)
# =========================================================================

# 1. Docker Hub Image Registry & Tags
SERVER_IMAGE=yourdockerusername/contproj-server:latest
ADMIN_IMAGE=yourdockerusername/contproj-admin:latest
STAFF_IMAGE=yourdockerusername/contproj-staff:latest
CLIENT_IMAGE=yourdockerusername/contproj-client:latest

# 2. Host VPS Mount Paths
UPLOADS_VOLUME_PATH=/www/wwwroot/server.yourdomain.com/uploads
LOGS_VOLUME_PATH=/www/wwwroot/server.yourdomain.com/logs

# 3. Backend Node Environment Configurations
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://host.docker.internal:27017/continental_service

# 4. Secrets (Generate secure random values for production)
JWT_ACCESS_SECRET=your_super_secure_production_access_key
JWT_REFRESH_SECRET=your_super_secure_production_refresh_key

# 5. JWT Expiration & Cookie Details
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_NAME_REFRESH=refreshToken
LOG_RETENTION_DAYS=7

# 6. Cors Allowed Origins (Comma separated)
FRONTEND_URL=https://client.yourdomain.com,https://staff.yourdomain.com,https://admin.yourdomain.com

# 7. Frontend API Target (Vite compile-time variable)
VITE_API_URL=https://api.yourdomain.com/api/v1

