{
  "name": "continental-tally-sync-agent",
  "version": "1.0.0",
  "description": "Local Sync Agent for connecting Continental ERP and Tally.ERP 9 / TallyPrime",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamnxd/Continental-Erp.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "fast-xml-parser": "^4.3.6",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.continental.tallysyncagent",
    "productName": "Continental Tally Sync Agent",
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "ui/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Continental Tally Sync Agent",
      "runAfterFinish": true
    }
  }
}
